# auth-server configuration
# Copy this file to .env and adjust values.

# Server listen address. Use 0.0.0.0 to accept external connections.
SERVER_HOST=127.0.0.1

# Server listen port.
SERVER_PORT=8080

# Allowed CORS origins (comma separated). Only used in --prod mode.
# In --dev mode all origins are allowed.
CORS_ALLOWED_ORIGINS=https://app.juragansejati.biz.id

# Cookie name for session ID.
AUTH_COOKIE_NAME=session_id

# Cookie path.
AUTH_COOKIE_PATH=/

# Restrict cookie to specific domain (optional, leave empty for default).
# AUTH_COOKIE_DOMAIN=example.com

# Send cookie only over HTTPS. Must be true in production.
AUTH_COOKIE_SECURE=true

# Prevent JavaScript access to cookie.
AUTH_COOKIE_HTTP_ONLY=true

# SameSite policy: Strict, Lax, or None.
# Use None for cross‑site requests (requires Secure=true).
AUTH_COOKIE_SAME_SITE=none

# Session lifetime in seconds (default: 86400 = 24 hours).
AUTH_SESSION_LIFETIME=86400

# Idle timeout in seconds (optional). Session expires after this period of inactivity.
# AUTH_SESSION_IDLE_TIMEOUT=1800

# URL to redirect after logout (optional). If not set, a JSON response is returned.
# AUTH_LOGOUT_REDIRECT_URL=/bye